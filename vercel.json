{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/ping",
            "destination": "/api/ping.js"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}